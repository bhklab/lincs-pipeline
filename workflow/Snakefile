checkpoint build_compound_manifest:
    input:
        cell_metadata_ready=CELL_METADATA_STAMP,
        compound_metadata_ready=COMPOUND_METADATA_STAMP,
        gene_metadata_ready=GENE_METADATA_STAMP,
        signature_metadata_ready=SIGNATURE_METADATA_STAMP,
        annotationdb_cache=ANNOTATIONDB_CACHE,
    output:
        manifest_tsv=COMPOUND_MANIFEST,
        summary_tsv=COMPOUND_MANIFEST_SUMMARY,
        feature_metadata_tsv=SIGNATURE_FEATURE_METADATA,
        gene_metadata_tsv=SELECTED_GENE_METADATA,
    params:
        cell_metadata=CELL_METADATA,
        compound_metadata=COMPOUND_METADATA,
        gene_metadata=GENE_METADATA,
        signature_metadata=SIGNATURE_METADATA,
        annotationdb_cache=ANNOTATIONDB_CACHE,
        compound_input_dir=COMPOUND_INPUT_DIR,
    script:
        "scripts/build_manifest.py"


@lru_cache(maxsize=1)
def manifest_rows():
    manifest_path = checkpoints.build_compound_manifest.get().output.manifest_tsv

    with open(manifest_path, newline="", encoding="utf-8") as handle:
        rows = list(DictReader(handle, delimiter="\t"))

    if not rows:
        raise ValueError(
            "Compound manifest is empty. Adjust the configured LINCS selection filters."
        )

    return rows


def compound_signature_targets(_wildcards):
    return [
        f"{COMPOUND_SIGNATURE_DIR}/{row['compound_id']}.tsv" for row in manifest_rows()
    ]


def compound_metadata_targets(_wildcards):
    return [
        f"{COMPOUND_METADATA_DIR}/{row['compound_id']}.tsv" for row in manifest_rows()
    ]


def compound_input_path(wildcards):
    checkpoints.build_compound_manifest.get().output.manifest_tsv
    return f"{COMPOUND_INPUT_DIR}/{wildcards.compound_id}.tsv"


rule compute_compound_signature:
    input:
        manifest_tsv=lambda _wildcards: checkpoints.build_compound_manifest.get().output.manifest_tsv,
        feature_metadata_tsv=lambda _wildcards: checkpoints.build_compound_manifest.get().output.feature_metadata_tsv,
        gene_metadata_tsv=lambda _wildcards: checkpoints.build_compound_manifest.get().output.gene_metadata_tsv,
        expression_matrix_ready=TREATMENT_MATRIX_STAMP,
    output:
        signature_tsv=f"{COMPOUND_SIGNATURE_DIR}/{{compound_id}}.tsv",
        metadata_tsv=f"{COMPOUND_METADATA_DIR}/{{compound_id}}.tsv",
    params:
        compound_input_path=compound_input_path,
        expression_matrix=TREATMENT_MATRIX,
        only_nonnegative_signatures=lambda _wildcards: parse_bool(
            selection_cfg.get("only_nonnegative_signatures", True)
        ),
    script:
        "scripts/compute_compound_signature.py"


rule build_processed_tables:
    input:
        manifest_tsv=lambda _wildcards: checkpoints.build_compound_manifest.get().output.manifest_tsv,
        feature_metadata_tsv=lambda _wildcards: checkpoints.build_compound_manifest.get().output.feature_metadata_tsv,
        signature_tsvs=compound_signature_targets,
        metadata_tsvs=compound_metadata_targets,
    output:
        signatures_csv=SIGNATURES_CSV,
        coldata_csv=COLDATA_CSV,
        compound_metadata_tsv=CURATED_COMPOUND_METADATA,
    script:
        "scripts/aggregate_results.py"


rule build_multiassayexperiment:
    input:
        signatures_csv=SIGNATURES_CSV,
        coldata_csv=COLDATA_CSV,
        compound_metadata_tsv=CURATED_COMPOUND_METADATA,
        feature_metadata_tsv=lambda _wildcards: checkpoints.build_compound_manifest.get().output.feature_metadata_tsv,
        gene_metadata_tsv=lambda _wildcards: checkpoints.build_compound_manifest.get().output.gene_metadata_tsv,
        configfile="config/pipeline.yaml",
    output:
        mae_rds=MAE_RDS,
    params:
        dataset_id=DATASET_ID,
        dataset_version=DATASET_VERSION,
    script:
        "scripts/build_mae.R"


rule export_mae_tables:
    input:
        mae_rds=MAE_RDS,
        configfile="config/pipeline.yaml",
    output:
        outdir=directory(TABLE_DIR),
    script:
        "scripts/export_mae_tables.R"


rule archive_mae_tables:
    input:
        outdir=TABLE_DIR,
    output:
        archive=TABLE_ARCHIVE,
    shell:
        """
        set -euo pipefail
        mkdir -p "$(dirname "{output.archive}")"
        COPYFILE_DISABLE=1 tar -C "{RESULTS_DIR}" -cf - "$(basename "{input.outdir}")" | gzip -9 > "{output.archive}"
        """


